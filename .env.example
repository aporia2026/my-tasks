# Copy to .env.local and fill in. Never commit .env.local.

# Neon Postgres connection string (from Vercel Marketplace or neon.com)
DATABASE_URL=

# OpenAI API key (platform.openai.com/api-keys)
OPENAI_API_KEY=

# Vercel Blob read-write token (created with the Blob store)
BLOB_READ_WRITE_TOKEN=

# Long random string used to sign the session cookie.
# Generate one with: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
AUTH_SECRET=

# The passcode you type on the login screen. Pick something long.
DASHBOARD_PASSCODE=
