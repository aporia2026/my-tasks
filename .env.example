# Copy to .env.local and fill in. Never commit .env.local.

# Neon Postgres connection string (from Vercel Marketplace or neon.com)
DATABASE_URL=

# OpenAI API key (platform.openai.com/api-keys)
OPENAI_API_KEY=

# Vercel Blob read-write token (created with the Blob store)
BLOB_READ_WRITE_TOKEN=

# Long random string used to sign the session cookie.
# Generate one with: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
AUTH_SECRET=

# The owner's email. This address self-provisions as the admin on first
# sign-in; everyone else must be invited from inside the app.
ADMIN_EMAIL=

# SMTP for sign-in links and notifications. Defaults target Gmail: use a Google
# account with 2-step verification on, then generate a 16-character app password
# (myaccount.google.com/apppasswords) and paste it as SMTP_PASS.
# Optional in local dev: without SMTP_USER/SMTP_PASS, emails are skipped and the
# sign-in link is printed to the server console instead.
SMTP_USER=
SMTP_PASS=

# Optional. Defaults suit Gmail; change only for a different SMTP host.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# Optional display name/address. Defaults to "My Tasks <SMTP_USER>". Gmail
# rewrites the address to the authenticated account regardless.
EMAIL_FROM=
